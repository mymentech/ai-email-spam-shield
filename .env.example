# AI Email Spam Shield — environment config
# Copy this file to .env and fill in your values.
# .env is gitignored and never shipped in release zips.
#
# These values override the Settings page in wp-admin.
# Leave blank to use wp-admin settings instead.

AIESS_API_URL=https://your-spam-api-host.com/predict
AIESS_API_KEY=your-api-key-here
